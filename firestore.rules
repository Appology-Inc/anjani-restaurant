rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      // Adding a safe default to prevent crashing if the document is missing
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc != null ? doc.data.role : 'customer';
    }
    
    function isOwner() {
      return isAuthenticated() && getUserRole() == 'owner';
    }
    
    function isRider() {
      return isAuthenticated() && getUserRole() == 'rider';
    }
    
    function isCustomer() {
      return isAuthenticated() && getUserRole() == 'customer';
    }

    // --- Users Collection ---
    // Users can only read their own profile document
    // Users can create/update their profile but cannot escalate their privileges
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == 'customer');
      allow update: if isAuthenticated() && request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // --- Menu Collection ---
    // Anyone can read the menu; only the owner can modify it
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isOwner();
    }
    
    // --- Settings Collection ---
    // Anyone can read settings (restaurant status, payment config); only the owner can modify
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // --- Orders Collection ---
    // Authenticated users can create orders if they set their own customerUid
    // Users can read their own orders; owners and riders can read all orders
    // Only owners and riders can arbitrarily update orders. 
    // Customers can only update their own orders without modifying critical fields.
    match /orders/{orderId} {
      allow create: if isAuthenticated() && request.resource.data.customerUid == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.customerUid == request.auth.uid ||
        isOwner() ||
        isRider()
      );
      allow update: if isAuthenticated() && (
        isOwner() || 
        isRider() || 
        (resource.data.customerUid == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalAmount', 'paymentStatus', 'status', 'items']))
      );
      allow delete: if isOwner();
    }
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
