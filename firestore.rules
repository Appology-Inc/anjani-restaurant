rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the requester is an owner
    function isOwner() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Authenticated users can read profiles (Customer needs Rider details, etc.)
      allow read: if request.auth != null;
      // Users can edit their own profile, or Owners can edit any profile
      allow write: if request.auth != null && (request.auth.uid == userId || isOwner());
    }

    // --- Menu Collection ---
    match /menu/{itemId} {
      // Anyone can read the menu (even before logging in)
      allow read: if true;
      // Only Owners can manage the menu
      allow write: if isOwner();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Authenticated users can read their orders (or Riders fetching the list)
      allow read: if request.auth != null;
      // Any authenticated user can create an order
      allow create: if request.auth != null;
      // Any authenticated user can update (Riders accepting, Customers canceling, Owners managing)
      allow update: if request.auth != null;
      // Only Owners can hard-delete orders
      allow delete: if isOwner();
    }

    // --- Settings Collection ---
    match /settings/{settingId} {
      // Anyone can read app settings
      allow read: if true;
      // Only Owners can change settings
      allow write: if isOwner();
    }
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
