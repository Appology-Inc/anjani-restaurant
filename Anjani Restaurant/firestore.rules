rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isOwner() {
      return isAuthenticated() && getUserRole() == 'owner';
    }
    function isRider() {
      return isAuthenticated() && getUserRole() == 'rider';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Menu Collection — public read, owner write
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Orders Collection
    // READ: fully public — all apps (customer, owner, rider) need to read the full collection
    // This avoids onSnapshot permission failures for anonymous/unauthenticated users
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner() ||
        isRider() ||
        resource.data.customerUid == request.auth.uid
      );
      allow delete: if isOwner();
    }

    // Settings Collection — public read (restaurant open/close), owner write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
